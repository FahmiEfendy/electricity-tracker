# Database Configuration
DB_HOST="localhost"
DB_PORT="5432"
DB_USER="postgres"
DB_PASSWORD="your_database_password"
DB_NAME="electricity_tracker"
DB_SCHEMA="public"

# Application Authentication
# Run `openssl rand -hex 32` to generate a secret
AUTH_SECRET="your_next_auth_secret_here"

# Admin Credentials
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="super_secure_admin_password"
